{
  "description": "New High Score default templates",
  "author": "New High Score",
  "license": "ISC",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/newhighsco/.github.git"
  },
  "homepage": "https://github.com/newhighsco/github#readme",
  "bugs": {
    "url": "https://github.com/newhighsco/github/issues"
  },
  "packageManager": "yarn@4.15.0",
  "scripts": {
    "prepare": "husky",
    "test": "yarn lint",
    "lint": "concurrently 'yarn:lint:*'",
    "lint:js": "yarn eslint --cache .",
    "lint:renovate": "renovate-config-validator renovate-config.json --strict",
    "format": "concurrently 'yarn:format:*'",
    "format:js": "yarn lint:js --fix"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@newhighsco/commitlint-config": "1.3.0",
    "@newhighsco/editor-config": "1.2.0",
    "@newhighsco/eslint-config": "7.1.3",
    "@newhighsco/lint-staged-config": "1.1.0",
    "@newhighsco/prettier-config": "2.3.5",
    "@newhighsco/yarn-plugin-preset": "1.1.4",
    "concurrently": "10.0.0",
    "eslint": "10.4.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "renovate": "43.202.1"
  },
  "commitlint": {
    "extends": [
      "@newhighsco"
    ]
  },
  "prettier": "@newhighsco/prettier-config"
}
